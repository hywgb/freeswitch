<profile name="external">
  <gateways/>
  <domains>
    <domain name="all" alias="true" parse="false"/>
  </domains>
  <settings>
    <param name="user-agent-string" value="FreeSWITCH"/>

    <!-- Bind external addresses/ports -->
    <param name="sip-ip" value="$${local_ip_v4}"/>
    <param name="rtp-ip" value="$${local_ip_v4}"/>
    <param name="sip-port" value="$${external_sip_port}"/>
    <param name="ext-rtp-ip" value="$${external_rtp_ip}"/>
    <param name="ext-sip-ip" value="$${external_sip_ip}"/>

    <!-- Route into public dialplan for strict handling -->
    <param name="context" value="public"/>

    <!-- NAT/ACL -->
    <param name="apply-nat-acl" value="nat.auto"/>
    <param name="apply-inbound-acl" value="external-sip"/>

    <!-- RTP timing and optional jitter buffer -->
    <param name="rtp-timer-name" value="soft"/>
    <!-- <param name="auto-jitterbuffer-msec" value="60"/> -->

    <!-- Security hardening -->
    <param name="auth-calls" value="true"/>
    <param name="inbound-reg-force-matching-username" value="true"/>
    <param name="auth-all-packets" value="false"/>
    <param name="nonce-ttl" value="60"/>
    <param name="disable-register" value="true"/>

    <!-- TLS: enforce TLS-only on external profile (configure certs before enabling) -->
    <param name="tls" value="true"/>
    <param name="tls-only" value="true"/>
    <param name="tls-bind-params" value="transport=tls"/>
    <param name="tls-sip-port" value="$${external_tls_port}"/>
    <param name="tls-cert-dir" value="/etc/freeswitch/tls"/>
    <param name="tls-verify-date" value="true"/>
    <param name="tls-verify-policy" value="none"/>
    <param name="tls-verify-depth" value="2"/>
    <param name="tls-version" value="$${sip_tls_version}"/>
    <param name="tls-ciphers" value="$${sip_tls_ciphers}"/>
  </settings>
</profile>