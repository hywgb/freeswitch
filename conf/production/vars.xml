<include>
  <X-PRE-PROCESS cmd="set" data="domain=$${local_ip_v4}"/>
  <X-PRE-PROCESS cmd="set" data="domain_name=$${domain}"/>
  <X-PRE-PROCESS cmd="set" data="external_sip_ip=auto"/>
  <X-PRE-PROCESS cmd="set" data="external_rtp_ip=auto"/>
  <X-PRE-PROCESS cmd="set" data="internal_sip_port=5060"/>
  <X-PRE-PROCESS cmd="set" data="external_sip_port=5080"/>
  <X-PRE-PROCESS cmd="set" data="default_password=REPLACE_ME"/>

  <!-- Codec preferences: narrowband then wideband (adjust to your environment) -->
  <X-PRE-PROCESS cmd="set" data="global_codec_prefs=OPUS,G722,PCMU,PCMA"/>
  <X-PRE-PROCESS cmd="set" data="outbound_codec_prefs=$${global_codec_prefs}"/>

  <!-- Feature flags -->
  <X-PRE-PROCESS cmd="set" data="enable_test_apps=false"/>

  <!-- TLS defaults -->
  <X-PRE-PROCESS cmd="set" data="external_tls_port=5061"/>
  <X-PRE-PROCESS cmd="set" data="sip_tls_version=tlsv1.2"/>
  <X-PRE-PROCESS cmd="set" data="sip_tls_ciphers=HIGH:!aNULL:!MD5"/>
</include>