<configuration name="xml_cdr.conf" description="XML CDR Logger (Production)">
  <settings>
    <!-- Disable disk logging by default; prefer remote CDR via HTTP(S) -->
    <param name="log-dir" value=""/>
    <param name="log-b-leg" value="false"/>
    <param name="prefix-a-leg" value="true"/>
    <param name="encode" value="true"/>

